# InterviewHelper Environment Configuration
# Copy this file to .env.local and configure your settings

# ChromaDB Storage Path
CHROMA_DB_PATH=./chroma_db

# --- Embedding model ----------------------------------------------------
# Local sentence-transformers model used for embeddings. Point this at the
# bundled local copy to run fully offline (no HuggingFace download at runtime).
# Accepts a local path or a HuggingFace model id.
EMBEDDING_MODEL=./models/local_all-MiniLM-L6-v2

# Optional: Override ChromaDB path (advanced usage)
# CHROMA_DB_PATH=/data/vector_store

# --- Local LLM provider -------------------------------------------------
# Which local LLM backend to use: "mlx" (default, Apple Silicon) or "ollama".
LLM_PROVIDER=mlx

# Optional overrides (else each provider uses its own default):
#   mlx    -> http://localhost:8080, model mlx-community/Qwen2.5-7B-Instruct-4bit
#   ollama -> http://localhost:11434, model llama3
# LLM_BASE_URL=http://localhost:8080
# LLM_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
